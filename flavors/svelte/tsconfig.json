{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2022",
      "DOM"
    ],
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*.ts"
  ]
}