{
  "name": "@planetlogin/store-sqlite",
  "version": "0.2.0",
  "type": "module",
  "description": "Batteries-included SQLite DownstreamStore for PlanetLogin — real accounts (password, OAuth, passkeys, TOTP, preferences) with zero downstream code.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@planetlogin/core": ">=0.9.0"
  },
  "devDependencies": {
    "@planetlogin/core": "*",
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
