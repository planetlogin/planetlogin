{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://planetlogin.org/config.schema.json",
  "title": "PlanetLogin white-label config",
  "description": "Single source of truth for branding, providers, copy and layout. Loaded identically from env vars (self-host) or the admin studio. The public subset is served at GET /auth/config; secrets (client secrets, downstream URL/secret, signing keys) are NEVER part of this schema.",
  "type": "object",
  "required": ["spec", "brand", "providers"],
  "additionalProperties": false,
  "properties": {
    "spec": { "const": 1, "description": "Spec version this config targets." },

    "brand": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "description": "Display name, e.g. \"Acme\"." },
        "logoUrl": { "type": "string", "format": "uri" },
        "accent": { "type": "string", "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$", "default": "#f6a13c" },
        "background": { "type": "string", "default": "#070b16" },
        "theme": {
          "type": "object",
          "description": "Optional semantic token overrides.",
          "additionalProperties": { "type": "string" }
        }
      }
    },

    "providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "password": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "allowRegister": { "type": "boolean", "default": false }
          }
        },
        "oauth": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "enum": ["google", "github", "apple", "microsoft", "gitlab", "discord"] },
              "label": { "type": "string" },
              "clientIdEnv": { "type": "string", "description": "Name of the env var holding the client id (secret stays in env)." }
            }
          },
          "default": []
        },
        "magicLink": {
          "type": "object", "additionalProperties": false,
          "properties": { "enabled": { "type": "boolean", "default": false }, "ttlSeconds": { "type": "integer", "default": 900 } }
        },
        "passkeys": {
          "type": "object", "additionalProperties": false,
          "properties": { "enabled": { "type": "boolean", "default": false } }
        },
        "totp": {
          "type": "object", "additionalProperties": false,
          "properties": { "enabled": { "type": "boolean", "default": false } }
        },
        "saml": {
          "type": "object", "additionalProperties": false,
          "description": "Enterprise SSO (optional, later tier). PlanetLogin acts as SP via an audited library.",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "idpMetadataUrl": { "type": "string", "format": "uri" }
          }
        }
      }
    },

    "copy": {
      "type": "object",
      "description": "Per-language string overrides. Key = BCP-47 language code; value = a map of copy keys to strings.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      },
      "default": {}
    },

    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "globePosition": { "type": "string", "enum": ["left", "right", "full"], "default": "left" },
        "showSearch": { "type": "boolean", "default": true },
        "autoSpin": { "type": "boolean", "default": true }
      }
    },

    "token": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "issuer": { "type": "string", "format": "uri" },
        "audience": { "type": "string" },
        "ttlSeconds": { "type": "integer", "default": 3600 },
        "algorithm": { "type": "string", "enum": ["EdDSA", "RS256"], "default": "EdDSA" }
      }
    }
  }
}
