{
  "name": "planetlogin",
  "version": "0.1.0",
  "description": "Sign in with a planet — interactive globe locale picker that detects timezone, language and location. Framework-agnostic (Web Component).",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "Ricard (Ricajos) (https://ricajos.com)",
  "homepage": "https://github.com/rricajos/planetlogin#readme",
  "repository": { "type": "git", "url": "git+https://github.com/rricajos/planetlogin.git" },
  "keywords": ["globe","locale","i18n","timezone","geolocation","login","onboarding","web-component","d3-geo"],
  "files": ["dist"],
  "main": "./dist/planetlogin.umd.cjs",
  "module": "./dist/planetlogin.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/planetlogin.js",
      "require": "./dist/planetlogin.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.dts.json",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.5",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
